# ============================================================
# SmartHire AI - Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ----- SERVER -----
PORT=5000
NODE_ENV=development

# ----- DATABASE (Required for Production) -----
# Get free MongoDB Atlas URI: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/smarthire-ai?retryWrites=true&w=majority

# ----- CACHE (Optional) -----
REDIS_URL=

# ----- AUTHENTICATION (Required) -----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRE=7d

# ----- FRONTEND URL (Required for CORS) -----
CLIENT_URL=http://localhost:5173

# ----- AI / ML (Optional - for AI features) -----
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ----- EMAIL (Optional - for OTP & password reset) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ----- FILE STORAGE (Optional - for uploads) -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- AWS S3 (Optional) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# ----- GOOGLE OAUTH (Optional - for Google login) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- LINKEDIN OAUTH (Optional) -----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
